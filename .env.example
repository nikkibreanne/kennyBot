# kennyBot environment contract — names only, NEVER commit real values.
# Copy to ".env" for local dev (.env is gitignored). In production these arrive
# at runtime via --env-file / mounted secrets, never baked into the image.

# ─── Twitch application (register at https://dev.twitch.tv/console/apps) ───
# Used by twurple's RefreshingAuthProvider to mint/refresh tokens for chat,
# Helix, and EventSub. The "app" client id/secret — shared by every token below.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ─── Bot chat account ───
# Display name of the account the bot logs in as (used to ignore its own echoes).
TWITCH_BOT_USERNAME=theKennyBot
# One-time bootstrap refresh token for the bot account (scopes: chat:read chat:edit).
# After first run the live token store (TOKEN_STORE_DIR) is authoritative and this
# is ignored. Obtain via the Twitch OAuth authorization-code flow.
TWITCH_BOT_REFRESH_TOKEN=

# ─── Channel ───
# Dev/test default is scasplte2 (the owner's personal channel). Prod: nikkibreanne.
TWITCH_CHANNEL=scasplte2

# ─── Broadcaster account (OPTIONAL — enables EventSub stream.online/offline) ───
# Refresh token for the *broadcaster* (channel owner) account. Required only for
# push-based live detection via EventSub-WS. If omitted, the bot falls back to
# the Helix poll (cheaper, slightly laggier). If the bot account IS the
# broadcaster (single-account dev), reuse the bot token here.
TWITCH_BROADCASTER_REFRESH_TOKEN=

# ─── Firebase RTDB ───
# Real project: point GOOGLE_APPLICATION_CREDENTIALS at a mounted service-account
# JSON and set the DB URL. The service account bypasses all RTDB rules — give it
# the minimum role (RTDB read/write on this DB only), never project Owner.
GOOGLE_APPLICATION_CREDENTIALS=
# Real okrafans RTDB lives in the asia-southeast1 region (matches the website).
FIREBASE_DATABASE_URL=https://okrafans-default-rtdb.asia-southeast1.firebasedatabase.app
# Firebase project id (also used as the RTDB namespace under the emulator).
FIREBASE_PROJECT_ID=okrafans
# Local emulator only — when set, the Admin SDK targets the emulator and no real
# credentials are needed. Leave EMPTY in production.
# FIREBASE_DATABASE_EMULATOR_HOST=127.0.0.1:9000

# ─── Runtime ───
# Directory for the persisted refresh-token store (§F). Leave UNSET in normal use:
# the container image already defaults this to /data (the mounted, runtime-user-
# owned volume), and bare `node index.js` defaults to ./.tokens. If you set it
# here it will OVERRIDE the image default when you pass --env-file (which is how a
# stray ./.tokens lands the container on a read-only path). Only uncomment to
# force a custom path, and make sure that path is writable by the runtime user.
# TOKEN_STORE_DIR=./.tokens
# Stable id for the single-instance lease (defaults to hostname:pid if unset).
# INSTANCE_ID=
# debug | info | warn | error
LOG_LEVEL=info
